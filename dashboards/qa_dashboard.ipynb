   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Load QA report\n",
    "report = pd.read_csv('qa_report.csv')\n",
    "issue_counts = report['issue'].value_counts()\n",
    "\n",
    "# Bar chart of issues\n",
    "issue_counts.plot(kind='bar', title='QA Issues Summary')\n",
    "plt.ylabel('Number of Records')\n",
    "plt.show()"
   ]
  }
